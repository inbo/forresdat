      "profile": "tabular-data-resource",
      "format": "csv",
      "mediatype": "text/csv",
      "encoding": "utf-8",
      "description": "rejuvenation values on plot level (or subplot level in case of core area)",
      "schema": {
        "fields": [
          {
            "name": "plottype",
            "type": "string",
            "description": {}
          },
          {
            "name": "plot_id",
            "type": "integer",
            "description": "unique sample plot id"
          },
          {
            "name": "year",
            "type": "integer",
            "description": "year of regeneration survey"
          },
          {
            "name": "period",
            "type": "integer",
            "description": "period: \"1\" for 1st decade (2000-2010), \"2\" for 2nd decade (2011-2020), \"3\" for 3th decade (2021-2030)"
          },
          {
            "name": "subplot_id",
            "type": "integer",
            "description": "id of subplot (1 for circular plots)"
          },
          {
            "name": "number_of_tree_species",
